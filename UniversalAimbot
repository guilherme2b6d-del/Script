local BONES = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
}
local N_BONES = #BONES

local PART_CACHE_NAMES = {}
do
    local seen={}
    for _,p in ipairs(BONES) do for _,n in ipairs(p) do
        if not seen[n] then seen[n]=true; table.insert(PART_CACHE_NAMES,n) end
    end end
    for _,n in ipairs({"HumanoidRootPart","Head","UpperTorso","LowerTorso"}) do
        if not seen[n] then seen[n]=true; table.insert(PART_CACHE_NAMES,n) end
    end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- DRAWING HELPERS
-- ─────────────────────────────────────────────────────────────────────────────
local function newLine(col,thick)
    local d=Drawing.new("Line"); d.Visible=false; d.Color=col; d.Thickness=thick; d.Transparency=1; return d
end
local function newText(col,sz,outline)
    local d=Drawing.new("Text"); d.Visible=false; d.Color=col; d.Size=sz
    d.Center=true; d.Outline=outline or false; d.Transparency=1; d.Font=Drawing.Fonts.UI; return d
end
local TAU=math.pi*2
local function newCircleLines(col,thick,segs)
    local t=table.create(segs); for i=1,segs do t[i]=newLine(col,thick) end; return t
end
local function setCircle(ls,cx,cy,r,vis)
    local n=#ls
    if not vis or r<=1 then for i=1,n do ls[i].Visible=false end; return end
    for i=1,n do
        local a0=TAU*(i-1)/n; local a1=TAU*i/n
        ls[i].From=Vector2.new(cx+r*math.cos(a0),cy+r*math.sin(a0))
        ls[i].To=Vector2.new(cx+r*math.cos(a1),cy+r*math.sin(a1)); ls[i].Visible=true
    end
end
local function setBox(ls,x1,y1,x2,y2,vis)
    if not vis then for i=1,4 do ls[i].Visible=false end; return end
    ls[1].From=Vector2.new(x1,y1); ls[1].To=Vector2.new(x2,y1)
    ls[2].From=Vector2.new(x1,y2); ls[2].To=Vector2.new(x2,y2)
    ls[3].From=Vector2.new(x1,y1); ls[3].To=Vector2.new(x1,y2)
    ls[4].From=Vector2.new(x2,y1); ls[4].To=Vector2.new(x2,y2)
    for i=1,4 do ls[i].Visible=true end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- WORLD → SCREEN
-- ─────────────────────────────────────────────────────────────────────────────
local function w2s(pos)
    local sp,vis=Camera:WorldToViewportPoint(pos); return Vector2.new(sp.X,sp.Y),vis,sp.Z
end
local function tracerOriginPt()
    local vp=Camera.ViewportSize
    if S.TracerOrigin=="center" then return Vector2.new(vp.X*.5,vp.Y*.5)
    elseif S.TracerOrigin=="mouse" then return UIS:GetMouseLocation()
    else return Vector2.new(vp.X*.5,vp.Y) end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- VISIBILITY CHECK
-- ─────────────────────────────────────────────────────────────────────────────
local function isVisible(part)
    if not part or not part.Parent then return false end
    local origin=Camera.CFrame.Position
    local direction=part.Position-origin; local dist=direction.Magnitude
    if dist<0.1 then return true end
    local ignoreList={Camera,workspace.Terrain}
    local lpChar=LP.Character; if lpChar then table.insert(ignoreList,lpChar) end
    local targetChar=part.Parent; if targetChar then table.insert(ignoreList,targetChar) end
    local ray=RaycastParams.new()
    ray.FilterDescendantsInstances=ignoreList; ray.FilterType=Enum.RaycastFilterType.Exclude
    return workspace:Raycast(origin,direction.Unit*dist,ray)==nil
end

-- ─────────────────────────────────────────────────────────────────────────────
-- HIGHLIGHT
-- ─────────────────────────────────────────────────────────────────────────────
local function applyHL(data,char)
    if data.hl and data.hl.Parent then data.hl:Destroy() end
    local fc=S.HLFillColor
    if S.TeamColor and data.player.Team then fc=data.player.Team.TeamColor.Color end
    local hl=Instance.new("Highlight")
    hl.FillColor=fc; hl.OutlineColor=S.HLOutlineColor
    hl.FillTransparency=S.HLFillTrans; hl.OutlineTransparency=S.HLOutlineTrans
    hl.Adornee=char; hl.Parent=char; data.hl=hl
end
local function removeHL(data)
    if data.hl and data.hl.Parent then data.hl:Destroy() end; data.hl=nil
end

-- ─────────────────────────────────────────────────────────────────────────────
-- PLAYER DATA
-- ─────────────────────────────────────────────────────────────────────────────
local PlayerData={}

local function buildData(player)
    local sl=table.create(N_BONES)
    for i=1,N_BONES do sl[i]=newLine(S.SkelColor,S.SkelThickness) end
    return {
        player=player, char=nil, parts={}, allParts={}, hl=nil, skelLines=sl,
        tracerLine=newLine(S.TracerColor,S.TracerThickness),
        boxLines={newLine(S.BoxColor,S.BoxThickness),newLine(S.BoxColor,S.BoxThickness),
                  newLine(S.BoxColor,S.BoxThickness),newLine(S.BoxColor,S.BoxThickness)},
        nameText=newText(S.NameColor,S.NameSize,S.NameOutline),
        headCircle=newCircleLines(S.HeadColor,S.HeadThickness,S.HeadSegments),
    }
end
local function destroyData(data)
    removeHL(data)
    for i=1,N_BONES do data.skelLines[i]:Remove() end
    data.tracerLine:Remove()
    for i=1,4 do data.boxLines[i]:Remove() end
    data.nameText:Remove()
    for _,l in ipairs(data.headCircle) do l:Remove() end
end
local function cacheParts(data,char)
    data.char=char; data.parts={}; data.allParts={}
    if not char then return end
    for _,n in ipairs(PART_CACHE_NAMES) do data.parts[n]=char:FindFirstChild(n) end
    for _,d in ipairs(char:GetDescendants()) do
        if d:IsA("BasePart") and d.Name~="HumanoidRootPart" then table.insert(data.allParts,d) end
    end
end
local function hideAll(data)
    for i=1,N_BONES do data.skelLines[i].Visible=false end
    data.tracerLine.Visible=false; setBox(data.boxLines,0,0,0,0,false)
    data.nameText.Visible=false; setCircle(data.headCircle,0,0,0,false)
end

-- applyESPColor (defined here, after PlayerData)
applyESPColor = function(col)
    ESPColor=col; S.HLFillColor=col; S.SkelColor=col; S.TracerColor=col
    S.BoxColor=col; S.NameColor=col; S.HeadColor=col
    for _,data in pairs(PlayerData) do
        for i=1,N_BONES do data.skelLines[i].Color=col end
        data.tracerLine.Color=col
        for i=1,4 do data.boxLines[i].Color=col end
        data.nameText.Color=col
        for _,l in ipairs(data.headCircle) do l.Color=col end
        if Enabled.Highlight and data.char and data.char.Parent then applyHL(data,data.char) end
    end
end

