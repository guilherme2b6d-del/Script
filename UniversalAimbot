-- FOV CIRCLE
-- ─────────────────────────────────────────────────────────────────────────────
local fovCircle=newCircleLines(Color3.fromRGB(255,230,60),1.2,80)
local function drawFOVCircle()
    if Aimbot.ShowFOV and Aimbot.Enabled then
        local vp=Camera.ViewportSize; local cx,cy=vp.X*.5,vp.Y*.5
        local col=UIS:IsKeyDown(Aimbot.HoldKey) and Color3.fromRGB(80,255,140) or Color3.fromRGB(255,230,60)
        for _,l in ipairs(fovCircle) do l.Color=col end
        setCircle(fovCircle,cx,cy,Aimbot.FOV,true)
    else setCircle(fovCircle,0,0,0,false) end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- AIMBOT
-- ─────────────────────────────────────────────────────────────────────────────
local function getClosestInFOV()
    local vp=Camera.ViewportSize; local center=Vector2.new(vp.X*.5,vp.Y*.5)
    local best,bestDist=nil,Aimbot.FOV
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        local char=p.Character; if not char then continue end
        local part=char:FindFirstChild(Aimbot.TargetPart) or char:FindFirstChild("Head"); if not part then continue end
        local sp,vis=w2s(part.Position); if not vis then continue end
        local dist=(sp-center).Magnitude; if dist>=bestDist then continue end
        if Aimbot.VisCheck and not isVisible(part) then continue end
        bestDist=dist; best=p
    end
    return best
end

task.spawn(function()
    while true do
        task.wait(1)
        local ok,err=pcall(function()
            if Aimbot.Enabled then Aimbot.Target=getClosestInFOV()
            else Aimbot.Target=nil end
        end)
        if not ok then warn("[PHANTOM] Aimbot refresh:",err); Aimbot.Target=nil end
    end
end)

local function doAimbotStep()
    if not UIS:IsKeyDown(Aimbot.HoldKey) then Aimbot.Target=nil; return end
    if not Aimbot.Target then Aimbot.Target=getClosestInFOV() end
    if not Aimbot.Target then return end
    local char=Aimbot.Target.Character; if not char then Aimbot.Target=nil; return end
    local part=char:FindFirstChild(Aimbot.TargetPart) or char:FindFirstChild("Head")
    if not part then Aimbot.Target=nil; return end
    if Aimbot.VisCheck and not isVisible(part) then Aimbot.Target=nil; return end
    local _,vis=w2s(part.Position); if not vis then Aimbot.Target=nil; return end
    local lookDir=(part.Position-Camera.CFrame.Position).Unit
    local blended=Camera.CFrame.LookVector:Lerp(lookDir,Aimbot.Smoothness)
    Camera.CFrame=CFrame.new(Camera.CFrame.Position,Camera.CFrame.Position+blended)
end

