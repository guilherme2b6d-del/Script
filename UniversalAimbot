    if Misc.InfJumpConn then Misc.InfJumpConn:Disconnect(); Misc.InfJumpConn=nil end
end
local function enableNoclip()
    Misc.NoclipConn=RunService.Stepped:Connect(function()
        local char=LP.Character; if not char then return end
        for _,p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
    end)
end
local function disableNoclip()
    if Misc.NoclipConn then Misc.NoclipConn:Disconnect(); Misc.NoclipConn=nil end
    local char=LP.Character; if not char then return end
    for _,p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=true end end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- REGISTER / UNREGISTER
-- ─────────────────────────────────────────────────────────────────────────────
local function register(player)
    if player==LP or PlayerData[player] then return end
    local data=buildData(player); PlayerData[player]=data
    local function onChar(char)
        task.wait(0.5); cacheParts(data,char)
        if Enabled.Highlight then applyHL(data,char) end
    end
    if player.Character then onChar(player.Character) end
    player.CharacterAdded:Connect(onChar)
end
local function unregister(player)
    local data=PlayerData[player]; if not data then return end
    destroyData(data); PlayerData[player]=nil
end
for _,p in ipairs(Players:GetPlayers()) do register(p) end
Players.PlayerAdded:Connect(register); Players.PlayerRemoving:Connect(unregister)

-- ─────────────────────────────────────────────────────────────────────────────
-- ESP 1-SECOND REFRESH LOOP
-- ─────────────────────────────────────────────────────────────────────────────
task.spawn(function()
    while true do
        task.wait(1)
        local ok,err=pcall(function()
            for _,p in ipairs(Players:GetPlayers()) do
                if p~=LP and not PlayerData[p] then register(p) end
            end
            for player,_ in pairs(PlayerData) do
                if not player or not player.Parent then
                    local data=PlayerData[player]
                    if data then pcall(destroyData,data) end
                    PlayerData[player]=nil
                end
            end
            for player,data in pairs(PlayerData) do
                local ok2,err2=pcall(function()
                    local liveChar=player.Character
                    if liveChar and liveChar~=data.char then
                        cacheParts(data,liveChar)
                        if Enabled.Highlight then applyHL(data,liveChar) end
                    elseif liveChar and data.char==liveChar then
                        local root=data.parts["HumanoidRootPart"]
                        if not root or not root.Parent then
                            cacheParts(data,liveChar)
                            if Enabled.Highlight then applyHL(data,liveChar) end
                        end
                    elseif not liveChar and data.char then
                        data.char=nil; hideAll(data)
                    end
                end)
                if not ok2 then warn("[PHANTOM] ESP refresh player:",err2) end
            end
        end)
        if not ok then warn("[PHANTOM] ESP refresh loop:",err) end
    end
end)

-- ─────────────────────────────────────────────────────────────────────────────
-- MAIN RENDER LOOP
-- ─────────────────────────────────────────────────────────────────────────────
RunService.RenderStepped:Connect(function()
    pcall(drawFOVCircle)
    if Aimbot.Enabled then pcall(doAimbotStep) end
    local doSkel=Enabled.Skeleton; local doTrac=Enabled.Tracer
    local doBox=Enabled.Box; local doName=Enabled.Name; local doHead=Enabled.Head
    if not(doSkel or doTrac or doBox or doName or doHead) then return end
    local tOrigin=doTrac and tracerOriginPt() or nil
    for player,data in pairs(PlayerData) do
        pcall(function()
            local char=data.char; local parts=data.parts
            if not char or not char.Parent then
                hideAll(data)
                local nc=player.Character
                if nc and nc~=char then cacheParts(data,nc) end; return
            end
            local root=parts["HumanoidRootPart"]; local head=parts["Head"]
            local rootSP,rootVis; if root then rootSP,rootVis=w2s(root.Position) end
            if doSkel then
                for i,pair in ipairs(BONES) do
                    local pA=parts[pair[1]]; local pB=parts[pair[2]]; local ln=data.skelLines[i]
                    if pA and pB then
                        local sA,vA=w2s(pA.Position); local sB,vB=w2s(pB.Position)
                        if vA and vB then ln.From=sA;ln.To=sB;ln.Visible=true else ln.Visible=false end
                    else ln.Visible=false end
                end
            else for i=1,N_BONES do data.skelLines[i].Visible=false end end
            if doTrac and root and rootVis then
                data.tracerLine.From=tOrigin; data.tracerLine.To=rootSP; data.tracerLine.Visible=true
            else data.tracerLine.Visible=false end
            if doBox then
                local mnX,mnY=1e9,1e9; local mxX,mxY=-1e9,-1e9; local any=false
                for _,part in ipairs(data.allParts) do
                    if part and part.Parent then
                        local sp,vis=w2s(part.Position)
                        if vis then any=true
                            if sp.X<mnX then mnX=sp.X end; if sp.Y<mnY then mnY=sp.Y end
                            if sp.X>mxX then mxX=sp.X end; if sp.Y>mxY then mxY=sp.Y end
                        end
                    end
                end
                if any then setBox(data.boxLines,mnX-4,mnY-4,mxX+4,mxY+4,true)
                else setBox(data.boxLines,0,0,0,0,false) end
            else setBox(data.boxLines,0,0,0,0,false) end
            if doName and head then
                local aH=head.Position+Vector3.new(0,head.Size.Y*.5+S.NameOffset*.05,0)
                local nSP,nVis=w2s(aH)
                if nVis then
                    data.nameText.Text=player.DisplayName
                    data.nameText.Position=Vector2.new(nSP.X,nSP.Y-S.NameOffset)
                    data.nameText.Visible=true
                else data.nameText.Visible=false end
            else data.nameText.Visible=false end
            if doHead and head then
                local hH=head.Size.Y*.5
                local hTop,visTop,dTop=w2s(head.Position+Vector3.new(0,hH,0))
                local hBot=w2s(head.Position+Vector3.new(0,-hH,0))
                if visTop and dTop>0 then
                    setCircle(data.headCircle,(hTop.X+hBot.X)*.5,(hTop.Y+hBot.Y)*.5,math.abs(hTop.Y-hBot.Y)*.5,true)
                else setCircle(data.headCircle,0,0,0,false) end
            else setCircle(data.headCircle,0,0,0,false) end
        end)
    end
end)

-- ─────────────────────────────────────────────────────────────────────────────
-- ESP TOGGLE
-- ─────────────────────────────────────────────────────────────────────────────
local function toggleFeature(key,state)
    Enabled[key]=state
    if key=="Highlight" then
        for _,d in pairs(PlayerData) do
            if state then if d.char and d.char.Parent then applyHL(d,d.char) end
            else removeHL(d) end
        end; return
    end
    if not state then
        for _,d in pairs(PlayerData) do
            if key=="Skeleton" then for i=1,N_BONES do d.skelLines[i].Visible=false end
            elseif key=="Tracer" then d.tracerLine.Visible=false
            elseif key=="Box" then setBox(d.boxLines,0,0,0,0,false)
            elseif key=="Name" then d.nameText.Visible=false
            elseif key=="Head" then setCircle(d.headCircle,0,0,0,false) end
        end
    end
end

