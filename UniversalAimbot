    btn.BorderSizePixel=0; mkCorner(btn,7); mkStroke(btn,C.border,1)
    local listening=false; local conn2
    btn.MouseButton1Click:Connect(function()
        if listening then return end; listening=true
        btn.Text="Press key..."; btn.TextColor3=C.textDim
        conn2=UIS.InputBegan:Connect(function(input,gpe)
            if gpe then return end
            if input.UserInputType~=Enum.UserInputType.Keyboard then return end
            local kc=input.KeyCode
            if kc~=Enum.KeyCode.Escape then
                if onChange then onChange(kc) end; btn.Text="[ "..keyName(kc).." ]"
            else btn.Text="[ "..keyName(defaultKey).." ]" end
            btn.TextColor3=C.text; listening=false; conn2:Disconnect()
        end)
    end)
    return btn
end

