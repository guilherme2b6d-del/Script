-- Slider card
local function makeSlider(parent,yPos,label,minV,maxV,defV,fmtFn,onChange)
    local card=Instance.new("Frame",parent)
    card.Size=UDim2.new(1,-PAD*2,0,SLIDER_H); card.Position=UDim2.new(0,PAD,0,yPos)
    card.BackgroundColor3=C.bg3; card.BackgroundTransparency=0.25; card.BorderSizePixel=0
    mkCorner(card,10); mkStroke(card,C.border,1)

    local lbl=mkLbl(card,label,14,C.textDim)
    lbl.Size=UDim2.new(1,-90,0,20); lbl.Position=UDim2.new(0,14,0,12)

    local valLbl=mkLbl(card,fmtFn and fmtFn(defV) or tostring(defV),14,C.text,Enum.Font.GothamBold,Enum.TextXAlignment.Right)
    valLbl.Size=UDim2.new(0,80,0,20); valLbl.Position=UDim2.new(1,-88,0,12)

    local track=Instance.new("Frame",card)
    track.Size=UDim2.new(1,-28,0,5); track.Position=UDim2.new(0,14,0,46)
    track.BackgroundColor3=C.bg4; track.BorderSizePixel=0; mkCorner(track,3)

    local initPct=(defV-minV)/(maxV-minV)
    local fill=Instance.new("Frame",track)
    fill.Size=UDim2.new(initPct,0,1,0); fill.BackgroundColor3=C.text
    fill.BorderSizePixel=0; mkCorner(fill,3)

    local thumb=Instance.new("Frame",track)
    thumb.Size=UDim2.new(0,18,0,18); thumb.AnchorPoint=Vector2.new(0.5,0.5)
    thumb.Position=UDim2.new(initPct,0,0.5,0); thumb.BackgroundColor3=C.white
    thumb.BorderSizePixel=0; mkCorner(thumb,99); mkStroke(thumb,C.border,2)

    local value=defV; local dragging=false
    local function fromX(absX)
        local ta=track.AbsolutePosition; local ts=track.AbsoluteSize
        local pct=math.clamp((absX-ta.X)/ts.X,0,1)
        value=minV+(maxV-minV)*pct
        fill.Size=UDim2.new(pct,0,1,0); thumb.Position=UDim2.new(pct,0,0.5,0)
        valLbl.Text=fmtFn and fmtFn(value) or string.format("%.0f",value)
        if onChange then onChange(value) end
    end
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; fromX(i.Position.X) end end)
    UIS.InputChanged:Connect(function(i) if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then fromX(i.Position.X) end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
end

