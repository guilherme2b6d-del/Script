-- MENU TOGGLE KEY
-- ═════════════════════════════════════════════════════════════════════════════
local menuVisible=true
UIS.InputBegan:Connect(function(input,gpe)
    if gpe then return end
    if input.UserInputType~=Enum.UserInputType.Keyboard then return end
    if input.KeyCode==Misc.MenuKey then menuVisible=not menuVisible; Root.Visible=menuVisible end
end)

-- ═════════════════════════════════════════════════════════════════════════════
-- LOADING SEQUENCE  →  SHOW MAIN UI
-- ═════════════════════════════════════════════════════════════════════════════
local function runLoadingAndOpen()
    PassScreen.Visible=false
    LoadScreen.Visible=true

    local steps=#LOAD_STEPS
    for i,stepText in ipairs(LOAD_STEPS) do
        loadStatus.Text=stepText
        local pct=i/steps
        tw(barFill,TweenInfo.new(0.50,Enum.EasingStyle.Quad),{Size=UDim2.new(pct,0,1,0)})
        barPct.Text=string.format("%d%%",math.floor(pct*100))
        task.wait(0.55)
    end
    loadStatus.Text="Complete!"; barPct.Text="100%"
    task.wait(0.35)

    -- Fade out loader
    tw(LoadScreen,TweenInfo.new(0.45,Enum.EasingStyle.Quad),{BackgroundTransparency=1})
    task.wait(0.45)
    LoadScreen.Visible=false

    -- Fade in main UI
    Root.Visible=true; Root.BackgroundTransparency=1
    tw(Root,TweenInfo.new(0.35,Enum.EasingStyle.Quad),{BackgroundTransparency=0.28})
    print("[PHANTOM] v11.0 ready — Menu key: "..keyName(Misc.MenuKey))
end

-- ═════════════════════════════════════════════════════════════════════════════
-- PASSWORD SUBMIT LOGIC
-- ═════════════════════════════════════════════════════════════════════════════
local function tryPassword()
    local typed=pInput.Text
    if typed==CORRECT_PASSWORD then
        -- Green flash
        tw(pStroke,TI_F,{Color=Color3.fromRGB(60,210,90)})
        pBtn.Text="✓ Access Granted"; pBtn.TextColor3=Color3.fromRGB(60,210,90)
        task.wait(0.55)
        task.spawn(runLoadingAndOpen)
    else
        -- Red flash + shake + error message
        tw(pStroke,TI_F,{Color=Color3.fromRGB(210,60,60)})
        pErr.Text="Incorrect password."
        pInput.Text=""
        local origPos=PC.Position
        for _=1,3 do
            tw(PC,TweenInfo.new(0.05),{Position=UDim2.new(0.5,9,0.5,0)}); task.wait(0.07)
            tw(PC,TweenInfo.new(0.05),{Position=UDim2.new(0.5,-9,0.5,0)}); task.wait(0.07)
        end
        tw(PC,TweenInfo.new(0.07),{Position=origPos})
        task.wait(0.7)
        tw(pStroke,TI_F,{Color=C.border})
    end
end

pBtn.MouseButton1Click:Connect(function() task.spawn(tryPassword) end)
pInput.FocusLost:Connect(function(enter) if enter then task.spawn(tryPassword) end end)
