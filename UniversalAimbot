local function makeKeybind(parent,yPos,label,defaultKey,onChange)
    local card=makeCard(parent,yPos,label)
    local btn=Instance.new("TextButton",card)
    btn.Size=UDim2.new(0,110,0,30); btn.Position=UDim2.new(1,-118,0.5,-15)
